rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
        || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
      );
    }

    function isOrgMemberActive(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status in ['active', 'pending']
        )
      );
    }

    function isOrgOwnerOrAdmin(orgId) {
      let org = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      return isSignedIn() && (
        org.ownerUid == request.auth.uid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['admin', 'owner']
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'active'
        )
      );
    }

    function canManageOrganization(orgId) {
      let org = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      return isSignedIn() && (
        org.ownerUid == request.auth.uid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager']
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'active'
        )
      );
    }

    function enabledModulesUnchanged() {
      return request.resource.data.get('enabledModules', {}) == resource.data.get('enabledModules', {});
    }

    function orgSensitiveFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'ownerUid',
        'seatsLimit',
        'seatsUsed',
        'seatLimit',
        'plan',
        'planCode',
        'billingStatus',
        'status',
        'trialEndsAt',
        'businessEnabled'
      ]);
    }

    function canReadProject() {
      return isSignedIn() && (
        resource.data.ownerId == request.auth.uid
        || (resource.data.orgId != null && isOrgMember(resource.data.orgId))
      );
    }

    function canCreateProject() {
      return isSignedIn() && (
        (request.resource.data.ownerId == request.auth.uid
          && (!('orgId' in request.resource.data) || request.resource.data.orgId == null))
        || (request.resource.data.orgId != null
          && isOrgMemberActive(request.resource.data.orgId)
          && request.resource.data.orgId == request.resource.data.get('orgId', request.resource.data.orgId))
      );
    }

    function projectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function canAccessProjectId(projectId) {
      let p = projectData(projectId);
      return isSignedIn() && (
        p.ownerId == request.auth.uid
        || (p.orgId != null && isOrgMember(p.orgId))
      );
    }

    function canAccessWorkspace(workspaceId) {
      return isSignedIn() && (
        workspaceId == request.auth.uid
        || isOrgMember(workspaceId)
      );
    }

    function canAccessOrgScopedDoc() {
      return isSignedIn() && (
        (resource.data.ownerId == request.auth.uid && (!('orgId' in resource.data) || resource.data.orgId == null))
        || (resource.data.orgId != null && isOrgMember(resource.data.orgId))
      );
    }

    function canCreateOrgScopedDoc() {
      return isSignedIn() && (
        (request.resource.data.ownerId == request.auth.uid
          && (!('orgId' in request.resource.data) || request.resource.data.orgId == null))
        || (request.resource.data.orgId != null && isOrgMemberActive(request.resource.data.orgId))
      );
    }

    function inviteeEmailMatches() {
      return request.auth.token.email != null
        && resource.data.emailLower == request.auth.token.email.lower();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if false;
      allow update: if isOrgOwnerOrAdmin(orgId)
        || (canManageOrganization(orgId) && enabledModulesUnchanged() && orgSensitiveFieldsUnchanged());
      allow delete: if isOrgOwnerOrAdmin(orgId);

      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow create: if isSignedIn()
          && memberId == request.auth.uid
          && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role in ['admin', 'owner'];
        allow update, delete: if isOrgOwnerOrAdmin(orgId);
      }

      match /invites/{inviteId} {
        allow read: if isOrgOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }
    }

    match /invites/{inviteId} {
      allow create: if false;
      allow read: if isSignedIn()
        && (isOrgOwnerOrAdmin(resource.data.orgId) || inviteeEmailMatches());
      allow update: if isSignedIn() && isOrgOwnerOrAdmin(resource.data.orgId);
      allow delete: if false;
    }

    match /businessInviteLookup/{hash} {
      allow read, write: if false;
    }

    match /adminActivityLogs/{logId} {
      allow read, write: if false;
    }

    match /projects/{projectId} {
      allow read: if canReadProject();
      allow create: if canCreateProject();
      allow update, delete: if canReadProject();

      match /tasks/{taskId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /expenses/{expenseId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /quoteItems/{itemId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /materials/{materialId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /documents/{documentId} {
        allow read, write: if canAccessProjectId(projectId);
      }
    }

    match /quotes/{quoteId} {
      allow read: if canAccessOrgScopedDoc();
      allow create: if canCreateOrgScopedDoc();
      allow update, delete: if canAccessOrgScopedDoc();
    }

    match /customers/{customerId} {
      allow read: if canAccessOrgScopedDoc();
      allow create: if canCreateOrgScopedDoc();
      allow update, delete: if canAccessOrgScopedDoc();
    }

    match /workspaces/{workspaceId} {
      allow read: if canAccessWorkspace(workspaceId);

      match /projectDrafts/{draftId} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }

      match /aiDraftFiles/{fileId} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }

      match /projects/{projectId} {
        allow read, write: if canAccessWorkspace(workspaceId);

        match /tasks/{taskId} {
          allow read, write: if canAccessWorkspace(workspaceId);
        }

        match /materials/{materialId} {
          allow read, write: if canAccessWorkspace(workspaceId);
        }
      }

      match /customers/{customerId} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }

      match /documents/{documentId} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }
    }
  }
}

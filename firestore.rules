rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          || get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
        );
    }

    function orgMemberData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isOrgMemberActive(orgId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && (
          get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
          || (
            exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
            && (
              !('status' in orgMemberData(orgId))
              || orgMemberData(orgId).status in ['active', 'pending']
            )
          )
        );
    }

    function isOrgOwnerOrAdmin(orgId) {
      let org = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      return isSignedIn() && (
        org.ownerUid == request.auth.uid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['admin', 'owner']
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'active'
        )
      );
    }

    function canManageOrganization(orgId) {
      let org = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      return isSignedIn() && (
        org.ownerUid == request.auth.uid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager']
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'active'
        )
      );
    }

    /** Live operations dashboard: owner, admin, manager, accountant. */
    function canViewOrgOperations(orgId) {
      let org = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      return isSignedIn() && isOrgMemberActive(orgId) && (
        org.ownerUid == request.auth.uid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['admin', 'owner', 'manager', 'accountant']
        )
      );
    }

    function canReadTimeEntry() {
      return isSignedIn() && (
        resource.data.userId == request.auth.uid
        || (
          resource.data.projectId is string
          && exists(/databases/$(database)/documents/projects/$(resource.data.projectId))
          && (
            get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid
            || (
              get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.orgId != null
              && canViewOrgOperations(
                get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.orgId
              )
            )
          )
        )
      );
    }

    function timeEntryGpsHideUpdateValid() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['gpsStartHidden', 'gpsEndHidden', 'gpsHiddenReason', 'gpsHiddenBy', 'gpsHiddenAt', 'updatedAt'])
        && request.resource.data.gpsHiddenBy == request.auth.uid
        && (
          request.resource.data.gpsStartHidden == true
          || request.resource.data.gpsEndHidden == true
        );
    }

    function isDirectChatParticipant(chatData) {
      return chatData.type == 'direct'
        && chatData.participantUids is list
        && request.auth.uid in chatData.participantUids;
    }

    function canReadOrgChat(chatData) {
      return chatData.type == 'general' || isDirectChatParticipant(chatData);
    }

    function orgMemberDataFor(orgId, memberUid) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(memberUid)).data;
    }

    function isOrgMemberUid(orgId, memberUid) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == memberUid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(memberUid))
          && (
            !('status' in orgMemberDataFor(orgId, memberUid))
            || orgMemberDataFor(orgId, memberUid).status in ['active', 'pending']
          )
        );
    }

    function directChatCreateValid(orgId) {
      return request.resource.data.type == 'direct'
        && request.resource.data.participantUids is list
        && request.resource.data.participantUids.size() == 2
        && request.auth.uid in request.resource.data.participantUids
        && isOrgMemberUid(orgId, request.resource.data.participantUids[0])
        && isOrgMemberUid(orgId, request.resource.data.participantUids[1]);
    }

    function isOrgChatWriter(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
        || (
          exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && (
            !('status' in orgMemberData(orgId))
            || orgMemberData(orgId).status in ['active', 'pending']
          )
          && orgMemberData(orgId).role in ['owner', 'admin', 'manager', 'worker', 'member']
        )
      );
    }

    function enabledModulesUnchanged() {
      return request.resource.data.get('enabledModules', {}) == resource.data.get('enabledModules', {});
    }

    function orgServerFieldsUnchanged() {
      return request.resource.data.get('ownerUid', null) == resource.data.get('ownerUid', null)
        && request.resource.data.get('billingOwnerUid', null) == resource.data.get('billingOwnerUid', null)
        && request.resource.data.get('createdByUid', null) == resource.data.get('createdByUid', null)
        && request.resource.data.get('status', null) == resource.data.get('status', null)
        && request.resource.data.get('billingStatus', null) == resource.data.get('billingStatus', null)
        && request.resource.data.get('businessEnabled', null) == resource.data.get('businessEnabled', null)
        && request.resource.data.get('seatsLimit', null) == resource.data.get('seatsLimit', null)
        && request.resource.data.get('seatsUsed', null) == resource.data.get('seatsUsed', null)
        && request.resource.data.get('trialStartedAt', null) == resource.data.get('trialStartedAt', null)
        && request.resource.data.get('trialEndsAt', null) == resource.data.get('trialEndsAt', null)
        && request.resource.data.get('activeBusinessOrderId', null) == resource.data.get('activeBusinessOrderId', null);
    }

    function orgProfileEditableKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'legalName',
        'name',
        'billingEmail',
        'billingAddress',
        'companyIdentifiers',
        'contactName',
        'phone',
        'countryCode',
        'country',
        'currency',
        'timezone',
        'locale',
        'defaultLanguage',
        'taxProfile',
        'legalProfile',
        'marketConfigVersion',
        'updatedBy',
        'profile',
        'updatedAt',
        'slug',
        'domain',
        'subdomainEnabled',
        'slugUpdatedAt',
        'slugUpdatedBy'
      ]);
    }

    function onlyEnabledModulesChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'enabledModules',
        'updatedAt'
      ]);
    }

    function onlyEnabledWorkTypesChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'enabledWorkTypes',
        'updatedAt'
      ]);
    }

    function onlyGmailDisconnectIntegration() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['integrations', 'updatedAt'])
        && resource.data.get('integrations', {}).get('gmail', {}).get('status', '') == 'connected'
        && request.resource.data.get('integrations', {}).get('gmail', {}).get('status', '') == 'not_connected'
        && request.resource.data.get('integrations', {}).get('gmail', {}).get('mode', '') == 'oauth'
        && request.resource.data.get('integrations', {}).get('googleMaps', null)
            == resource.data.get('integrations', {}).get('googleMaps', null)
        && request.resource.data.get('integrations', {}).get('aiInvoiceOcr', null)
            == resource.data.get('integrations', {}).get('aiInvoiceOcr', null);
    }

    function orgSensitiveFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'ownerUid',
        'billingOwnerUid',
        'createdByUid',
        'seatsLimit',
        'seatsUsed',
        'seatLimit',
        'plan',
        'planCode',
        'billingStatus',
        'status',
        'trialStartedAt',
        'trialEndsAt',
        'trialStartedAt',
        'activeBusinessOrderId',
        'businessEnabled'
      ]);
    }

    function canReadProject() {
      return isSignedIn() && (
        resource.data.ownerId == request.auth.uid
        || (resource.data.orgId != null && isOrgMember(resource.data.orgId))
      );
    }

    function canCreateProject() {
      return isSignedIn() && (
        (request.resource.data.ownerId == request.auth.uid
          && (!('orgId' in request.resource.data) || request.resource.data.orgId == null))
        || (request.resource.data.orgId != null
          && isOrgMemberActive(request.resource.data.orgId)
          && request.resource.data.orgId == request.resource.data.get('orgId', request.resource.data.orgId))
      );
    }

    function projectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function canAccessProjectId(projectId) {
      let p = projectData(projectId);
      return isSignedIn() && (
        p.ownerId == request.auth.uid
        || (p.orgId != null && isOrgMember(p.orgId))
      );
    }

    function isAssignedOnProject(projectId) {
      let p = projectData(projectId);
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(projectId))
        && (
          (
            'assignedMemberIds' in p
            && p.assignedMemberIds is list
            && p.assignedMemberIds.hasAny([request.auth.uid])
          )
          || (
            exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid))
            && (
              !('status' in get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data)
              || get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.status == 'active'
            )
          )
        );
    }

    function canPublishFieldNote(projectId, orgId) {
      return isOrgMember(orgId)
        || (
          projectId is string
          && projectId != ''
          && exists(/databases/$(database)/documents/projects/$(projectId))
          && projectData(projectId).orgId == orgId
          && isAssignedOnProject(projectId)
        );
    }

    function memberFieldNoteNotificationCreateAllowed() {
      let oid = request.resource.data.orgId;
      let pid = request.resource.data.get('projectId', null);
      return request.resource.data.fromUserId == request.auth.uid
        && oid is string
        && oid.size() > 0
        && request.resource.data.type == 'FIELD_NOTE_SHARED'
        && request.resource.data.userId != request.auth.uid
        && (
          isOrgMember(oid)
          || (pid is string && pid != '' && canPublishFieldNote(pid, oid))
        );
    }

    function memberFieldNoteOfficeNotificationCreateAllowed(targetUserId) {
      let oid = request.resource.data.orgId;
      let pid = request.resource.data.get('projectId', null);
      return request.resource.data.assignedBy == request.auth.uid
        && oid is string
        && oid.size() > 0
        && request.resource.data.type == 'FIELD_NOTE_SHARED'
        && targetUserId != request.auth.uid
        && (
          isOrgMember(oid)
          || (pid is string && pid != '' && canPublishFieldNote(pid, oid))
        );
    }

    // Mobile compat: a project member may report/escalate a site problem and notify
    // the project owner/manager (or assignee). Problem notifications carry no orgId,
    // so access is gated by project assignment or org membership on the project.
    function memberProblemNotificationCreateAllowed() {
      let pid = request.resource.data.get('projectId', null);
      return request.resource.data.fromUserId == request.auth.uid
        && pid is string
        && pid != ''
        && exists(/databases/$(database)/documents/projects/$(pid))
        && (isAssignedOnProject(pid) || canAccessProjectId(pid))
        && request.resource.data.type in ['PROBLEM_ASSIGNED', 'PROBLEM_REPORTED']
        && request.resource.data.userId != request.auth.uid;
    }

    function memberProblemOfficeNotificationCreateAllowed(targetUserId) {
      let pid = request.resource.data.get('projectId', null);
      return targetUserId != request.auth.uid
        && pid is string
        && pid != ''
        && exists(/databases/$(database)/documents/projects/$(pid))
        && (
          request.resource.data.fromUserId == request.auth.uid
          || request.resource.data.assignedBy == request.auth.uid
        )
        && (isAssignedOnProject(pid) || canAccessProjectId(pid))
        && request.resource.data.type in ['PROBLEM_ASSIGNED', 'PROBLEM_REPORTED'];
    }

    // Mobile compat: a worker may request time off and notify org owner/managers.
    // Absence notifications carry the business orgId; the requester must be a member.
    function memberAbsenceNotificationCreateAllowed() {
      let oid = request.resource.data.orgId;
      return request.resource.data.fromUserId == request.auth.uid
        && oid is string
        && oid.size() > 0
        && request.resource.data.type == 'ABSENCE_REQUESTED'
        && request.resource.data.userId != request.auth.uid
        && isOrgMember(oid);
    }

    function memberAbsenceOfficeNotificationCreateAllowed(targetUserId) {
      let oid = request.resource.data.orgId;
      return request.resource.data.assignedBy == request.auth.uid
        && oid is string
        && oid.size() > 0
        && request.resource.data.type == 'ABSENCE_REQUESTED'
        && targetUserId != request.auth.uid
        && isOrgMember(oid);
    }

    function canAccessWorkspace(workspaceId) {
      return isSignedIn() && (
        workspaceId == request.auth.uid
        || isOrgMemberActive(workspaceId)
      );
    }

    function canAccessOrgScopedDoc() {
      return isSignedIn() && (
        resource.data.get('ownerId', null) == request.auth.uid
        || (resource.data.orgId != null && isOrgMemberActive(resource.data.orgId))
      );
    }

    function canCreateOrgScopedDoc() {
      return isSignedIn() && (
        request.resource.data.get('ownerId', null) == request.auth.uid
        || (request.resource.data.orgId != null && isOrgMemberActive(request.resource.data.orgId))
      );
    }

    function inviteeEmailMatches() {
      return request.auth.token.email != null
        && resource.data.emailLower == request.auth.token.email.lower();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        !exists(/databases/$(database)/documents/notifications/$(notificationId))
        || request.auth.uid == resource.data.userId
      );
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId
        || (
          request.resource.data.fromUserId == request.auth.uid
          && request.resource.data.orgId != null
          && canManageOrganization(request.resource.data.orgId)
        )
        || memberFieldNoteNotificationCreateAllowed()
        || memberProblemNotificationCreateAllowed()
        || memberAbsenceNotificationCreateAllowed()
      );
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      allow delete: if false;
    }

    // Mobile compat: collectionGroup("members") self-membership discovery (org + project).
    // Self-read (memberId == uid OR userId == uid) avoids get()-based parent lookups that
    // make the mobile collectionGroup query fail server-side. Mirrors mobile/firestore.rules.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn()
        && (memberId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    // Mobile compat: shared config/limits (mobile appUpdateService + plan limits). CF writes only.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /projectInvites/{inviteId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, update: if isSignedIn()
          && (
            request.auth.uid == userId
            || (
              request.resource.data.orgId != null
              && canManageOrganization(request.resource.data.orgId)
            )
          );
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn()
          && (
            request.auth.uid == userId
            || (
              request.resource.data.assignedBy == request.auth.uid
              && request.resource.data.orgId != null
              && canManageOrganization(request.resource.data.orgId)
            )
            || memberFieldNoteOfficeNotificationCreateAllowed(userId)
            || memberProblemOfficeNotificationCreateAllowed(userId)
            || memberAbsenceOfficeNotificationCreateAllowed(userId)
          );
        allow update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /equipment/{equipmentId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /equipment/{equipmentId}/{rest=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Mobile compat: CF-written indexes/limits — client read-only.
      match /projectRefs/{projectId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;
      }
      match /limits/{docId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;
      }
      match /usage/{docId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;
      }

      // Mobile compat: all other self-owned user subcollections (push tokens, settings, etc.).
      // Excludes CF-only and explicitly-handled subcollections above.
      match /{subcol}/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId
          && subcol != 'projectRefs' && subcol != 'limits' && subcol != 'usage'
          && subcol != 'notifications' && subcol != 'projectInvites' && subcol != 'equipment';
      }
      match /{subcol}/{docId}/{rest=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId
          && subcol != 'projectRefs' && subcol != 'limits' && subcol != 'usage'
          && subcol != 'notifications' && subcol != 'projectInvites' && subcol != 'equipment';
      }
    }

    function fieldNoteCreateValid(orgId) {
      let pid = request.resource.data.get('projectId', null);
      return isSignedIn()
        && request.resource.data.orgId == orgId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.shareWithManager == true
        && request.resource.data.status == 'open'
        && canPublishFieldNote(pid, orgId);
    }

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if false;
      allow update: if isOrgOwnerOrAdmin(orgId)
        && orgServerFieldsUnchanged()
        && orgProfileEditableKeysOnly();
      allow update: if canManageOrganization(orgId)
        && onlyEnabledModulesChanged()
        && orgServerFieldsUnchanged();
      allow update: if canManageOrganization(orgId)
        && onlyEnabledWorkTypesChanged()
        && orgServerFieldsUnchanged();
      allow update: if canManageOrganization(orgId)
        && onlyGmailDisconnectIntegration()
        && orgServerFieldsUnchanged();
      allow delete: if isOrgOwnerOrAdmin(orgId);

      match /liveTimers/{memberUid} {
        allow read: if isOrgMemberActive(orgId);
        allow create, update, delete: if isSignedIn()
          && request.auth.uid == memberUid
          && isOrgMemberActive(orgId);
      }

      // Mobile compat: org CRM contacts — read for active members, write for managers.
      match /contacts/{contactId} {
        allow read: if isOrgMemberActive(orgId);
        allow create, update: if canManageOrganization(orgId);
        allow delete: if false;
      }

      match /documentTemplates/{templateId} {
        // Align with organization read — any org member can read quote template design.
        allow read: if isOrgMember(orgId);
        allow create, update: if isOrgOwnerOrAdmin(orgId)
          && templateId == 'default-quote'
          && request.resource.data.type == 'quote';
        allow delete: if isOrgOwnerOrAdmin(orgId) && templateId == 'default-quote';
      }

      match /fieldNotes/{noteId} {
        allow read: if isOrgMember(orgId)
          && (canViewOrgOperations(orgId) || resource.data.createdBy == request.auth.uid);
        allow create: if fieldNoteCreateValid(orgId);
        allow update: if isSignedIn() && isOrgMemberActive(orgId)
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.orgId == resource.data.orgId
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.shareWithManager == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'text']);
        allow delete: if false;
      }

      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow create: if isSignedIn()
          && memberId == request.auth.uid
          && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role in ['admin', 'owner'];
        allow update, delete: if isOrgOwnerOrAdmin(orgId);
      }

      match /invites/{inviteId} {
        allow read: if isOrgOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }

      match /chats/{chatId} {
        allow read: if isOrgMemberActive(orgId) && canReadOrgChat(resource.data);
        allow create: if isSignedIn()
          && isOrgMemberActive(orgId)
          && request.resource.data.orgId == orgId
          && (
            (request.resource.data.type == 'general' && chatId == 'general')
            || (directChatCreateValid(orgId) && chatId.matches('direct_.*'))
          );
        allow update: if isSignedIn()
          && isOrgChatWriter(orgId)
          && canReadOrgChat(resource.data)
          && request.resource.data.orgId == resource.data.orgId
          && request.resource.data.type == resource.data.type
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title',
            'updatedAt',
            'lastMessageText',
            'lastMessageAt',
            'lastMessageByUid'
          ]);
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if isOrgMemberActive(orgId)
            && canReadOrgChat(get(/databases/$(database)/documents/organizations/$(orgId)/chats/$(chatId)).data);
          allow create: if isSignedIn()
            && isOrgChatWriter(orgId)
            && canReadOrgChat(get(/databases/$(database)/documents/organizations/$(orgId)/chats/$(chatId)).data)
            && request.resource.data.orgId == orgId
            && request.resource.data.chatId == chatId
            && request.resource.data.senderUid == request.auth.uid
            && request.resource.data.type in ['text', 'image']
            && request.resource.data.status == 'sent';
          allow update, delete: if false;
        }

        match /reads/{readUid} {
          allow read: if isOrgMemberActive(orgId)
            && canReadOrgChat(get(/databases/$(database)/documents/organizations/$(orgId)/chats/$(chatId)).data);
          allow create, update: if isSignedIn()
            && isOrgMemberActive(orgId)
            && canReadOrgChat(get(/databases/$(database)/documents/organizations/$(orgId)/chats/$(chatId)).data)
            && readUid == request.auth.uid
            && request.resource.data.uid == request.auth.uid;
          allow delete: if false;
        }
      }

      match /gmailConnections/{connectionId} {
        allow read, write: if false;
      }

      match /emailInquiries/{inquiryId} {
        allow read: if isOrgMemberActive(orgId);
        allow create, update: if canManageOrganization(orgId);
        allow delete: if isOrgOwnerOrAdmin(orgId);

        match /messages/{messageId} {
          allow read: if isOrgMemberActive(orgId);
          allow write: if canManageOrganization(orgId);
        }
      }
    }

    match /invites/{inviteId} {
      allow create: if false;
      allow read: if isSignedIn()
        && (isOrgOwnerOrAdmin(resource.data.orgId) || inviteeEmailMatches());
      allow update: if isSignedIn() && isOrgOwnerOrAdmin(resource.data.orgId);
      allow delete: if false;
    }

    match /businessInviteLookup/{hash} {
      allow read, write: if false;
    }

    match /adminActivityLogs/{logId} {
      allow read, write: if false;
    }

    // Mobile parity: delete/update require project owner or org manager+ (not every org member).
    function canManageProjectDoc() {
      return isSignedIn() && (
        resource.data.ownerId == request.auth.uid
        || (resource.data.orgId != null && canManageOrganization(resource.data.orgId))
      );
    }

    match /projects/{projectId} {
      allow read: if canReadProject();
      allow create: if canCreateProject();
      allow update, delete: if canManageProjectDoc();

      match /tasks/{taskId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /expenses/{expenseId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /quoteItems/{itemId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /materials/{materialId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /materialSuggestions/{suggestionId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /documents/{documentId} {
        allow read, write: if canAccessProjectId(projectId);
      }

      match /members/{memberId} {
        allow read: if canAccessProjectId(projectId);
        allow write: if canManageProjectDoc();
      }

      match /phases/{phaseId} {
        allow read: if canAccessProjectId(projectId);
        allow write: if canManageProjectDoc();
      }

      // Site problems (mobile: projects/{projectId}/problems)
      match /problems/{problemId} {
        allow read: if canAccessProjectId(projectId);
        allow create: if canAccessProjectId(projectId);
        allow update: if canAccessProjectId(projectId) || canManageProjectDoc();
        allow delete: if canManageProjectDoc();
      }

      // Mobile compat: construction diary, attachments, activity events.
      match /constructionDiary/{entryId} {
        allow read: if canAccessProjectId(projectId);
        allow create: if canAccessProjectId(projectId);
        allow update, delete: if canManageProjectDoc()
          || (canAccessProjectId(projectId) && resource.data.get('createdBy', null) == request.auth.uid);
      }

      match /attachments/{attachmentId} {
        allow read: if canAccessProjectId(projectId);
        allow create: if canAccessProjectId(projectId);
        allow update, delete: if canManageProjectDoc()
          || (canAccessProjectId(projectId) && resource.data.get('createdBy', null) == request.auth.uid);
      }

      match /events/{eventId} {
        allow read: if canAccessProjectId(projectId);
        allow write: if canAccessProjectId(projectId);
      }

      // membersByUid: CF-written membership index; client self-read only.
      match /membersByUid/{memberUid} {
        allow read: if isSignedIn() && request.auth.uid == memberUid;
        allow write: if false;
      }

      // Mobile compat: remaining project subcollections (stats, phaseStats, etc.).
      // Excludes the explicitly-handled subcollections above so their stricter
      // write rules (e.g. members/phases are manager-only) are not loosened.
      match /{subcol}/{docId} {
        allow read: if canAccessProjectId(projectId)
          && subcol != 'members' && subcol != 'phases' && subcol != 'membersByUid';
        allow write: if canAccessProjectId(projectId)
          && subcol != 'members' && subcol != 'phases' && subcol != 'membersByUid'
          && subcol != 'documents' && subcol != 'problems';
      }
      match /{subcol}/{docId}/{rest=**} {
        allow read: if canAccessProjectId(projectId)
          && subcol != 'members' && subcol != 'phases' && subcol != 'membersByUid';
        allow write: if canAccessProjectId(projectId)
          && subcol != 'members' && subcol != 'phases' && subcol != 'membersByUid'
          && subcol != 'documents' && subcol != 'problems';
      }
    }

    function isSoloQuoteWorkspaceType() {
      let wt = resource.data.get('workspaceType', null);
      return wt == null || wt == 'personal' || wt == 'solo';
    }

    function isSoloQuoteRequestWorkspaceType() {
      let wt = request.resource.data.get('workspaceType', null);
      return wt == null || wt == 'personal' || wt == 'solo';
    }

    function isCompanyQuoteWorkspaceType() {
      let wt = resource.data.get('workspaceType', null);
      return wt == 'team' || wt == 'company';
    }

    function canReadSoloQuoteDoc() {
      return isSignedIn()
        && resource.data.get('orgId', null) == null
        && isSoloQuoteWorkspaceType()
        && resource.data.get('ownerId', null) == request.auth.uid;
    }

    function canReadCompanyQuoteDoc() {
      return isSignedIn() && (
        (resource.data.orgId != null && isOrgMember(resource.data.orgId))
        || (
          resource.data.get('workspaceId', null) != null
          && isCompanyQuoteWorkspaceType()
          && isOrgMember(resource.data.workspaceId)
        )
      );
    }

    function canReadQuoteDoc() {
      return canReadCompanyQuoteDoc() || canReadSoloQuoteDoc();
    }

    function canWriteQuoteDoc() {
      return isSignedIn() && (
        (resource.data.orgId != null && canManageOrganization(resource.data.orgId))
        || (
          resource.data.get('orgId', null) == null
          && isSoloQuoteWorkspaceType()
          && resource.data.get('ownerId', null) == request.auth.uid
        )
        || (
          resource.data.get('workspaceId', null) != null
          && isCompanyQuoteWorkspaceType()
          && canManageOrganization(resource.data.workspaceId)
        )
      );
    }

    function canCreateQuoteDoc() {
      return isSignedIn() && (
        (
          request.resource.data.orgId != null
          && (
            canManageOrganization(request.resource.data.orgId)
            || isOrgMemberActive(request.resource.data.orgId)
          )
        )
        || (
          request.resource.data.get('orgId', null) == null
          && isSoloQuoteRequestWorkspaceType()
          && request.resource.data.get('ownerId', null) == request.auth.uid
        )
      );
    }

    match /quotes/{quoteId} {
      allow read: if canReadQuoteDoc();
      allow create: if canCreateQuoteDoc();
      allow update, delete: if canWriteQuoteDoc();
    }

    // Mobile compat: estimates share the same ownership model as quotes.
    match /estimates/{estimateId} {
      allow read: if canReadQuoteDoc();
      allow create: if canCreateQuoteDoc();
      allow update, delete: if canWriteQuoteDoc();
    }

    // Mobile compat: B2B registration orders (CF-managed), read for billing owner / org owner.
    match /businessOrders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.get('billingOwnerUid', null) == request.auth.uid
        || (resource.data.get('orgId', null) != null && isOrgOwnerOrAdmin(resource.data.orgId))
      );
      allow create, update, delete: if false;
    }

    // Mobile compat: billing events (CF-written), read by their owner only.
    match /billingEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.get('firebaseUID', null) == request.auth.uid;
      allow write: if false;
    }

    // Mobile compat: catalog templates (read-only reference data).
    match /catalogTemplates/{templateId} {
      allow read: if isSignedIn();
      allow write: if false;
      match /{doc=**} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    match /absences/{absenceId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || (resource.data.orgId != null && canViewOrgOperations(resource.data.orgId))
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orgId is string
        && (
          // Solo / personal namespace: AuthContext.orgId === uid (no organization doc).
          request.resource.data.orgId == request.auth.uid
          // Real B2B org: must be an active member.
          || isOrgMemberActive(request.resource.data.orgId)
        );
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || (resource.data.orgId != null && canManageOrganization(resource.data.orgId))
      );
    }

    match /timeEntries/{entryId} {
      allow read: if canReadTimeEntry();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.projectId is string
        && canAccessProjectId(request.resource.data.projectId);
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || (
          timeEntryGpsHideUpdateValid()
          && resource.data.projectId is string
          && exists(/databases/$(database)/documents/projects/$(resource.data.projectId))
          && (
            get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.orgId != null
            && canManageOrganization(
              get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.orgId
            )
          )
        )
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /customers/{customerId} {
      allow read: if canAccessOrgScopedDoc();
      allow create: if canCreateOrgScopedDoc();
      allow update, delete: if canAccessOrgScopedDoc();
    }

    match /workspaces/{workspaceId} {
      allow read: if canAccessWorkspace(workspaceId);

      match /projectDrafts/{draftId} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }

      match /aiDraftFiles/{fileId} {
        allow read: if canAccessWorkspace(workspaceId);
        allow create: if canAccessWorkspace(workspaceId)
          && request.resource.data.uploadedBy == request.auth.uid
          && request.resource.data.storagePath is string
          && request.resource.data.fileName is string;
        allow update, delete: if canAccessWorkspace(workspaceId);
      }

      match /projects/{projectId} {
        allow read, write: if canAccessWorkspace(workspaceId);

        match /tasks/{taskId} {
          allow read, write: if canAccessWorkspace(workspaceId);
        }

        match /materials/{materialId} {
          allow read, write: if canAccessWorkspace(workspaceId);
        }
      }

      match /customers/{customerId} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }

      match /documents/{documentId} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }
    }
  }
}

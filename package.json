  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "firebase": "firebase",
    "firebase:login": "firebase login --reauth",
    "firebase:login:no-localhost": "firebase login --reauth --no-localhost",

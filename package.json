{
  "name": "staveto-office",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/copy-pdf-worker.mjs",
    "dev": "node scripts/with-ca.mjs dev",
    "build": "node scripts/with-ca.mjs build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "diagnostics:workspace": "node scripts/run-workspace-diagnostics.mjs",
    "seed:knowledge": "node scripts/seed-knowledge-rest.mjs",
    "fetch:estimator-session": "node scripts/fetch-estimator-session.mjs",
    "test:ai-estimator-electrical-pdf": "node scripts/run-electrical-pdf-analysis.mjs && vitest run src/lib/ai/electricalPdfReport.acceptance.test.ts",
    "test:ai-estimator-visual-symbols": "vitest run src/lib/ai/visualSymbolCounter.acceptance.test.ts",
    "seed:knowledge:admin": "node scripts/seed-estimator-knowledge.mjs",
    "test:workspace": "vitest run",
    "firebase": "firebase",
    "firebase:login": "firebase login --reauth",
    "firebase:login:no-localhost": "firebase login --reauth --no-localhost",
    "firebase:login:workaround": "powershell -ExecutionPolicy Bypass -File scripts/firebase-login-attest-workaround.ps1",
    "firebase:secret": "firebase functions:secrets:set GEMINI_API_KEY",
    "firebase:deploy": "firebase deploy --only functions:generateProjectDraft,functions:updateProjectDraftWithAI,functions:createProjectFromDraft,functions:createBusinessOrg,functions:gmailOAuthCallback,functions:gmailBuildAuthUrl,firestore:rules,storage",
    "setup:gmail": "powershell -ExecutionPolicy Bypass -File scripts/setup-gmail.ps1",
    "setup:firebase-admin": "powershell -ExecutionPolicy Bypass -File scripts/setup-firebase-admin.ps1",
    "firebase:deploy:gmail": "powershell -ExecutionPolicy Bypass -File scripts/firebase-deploy-gmail.ps1",
    "firebase:grant:gmail": "powershell -ExecutionPolicy Bypass -File scripts/grant-gmail-invoker.ps1",
    "firebase:deploy:functions": "firebase deploy --only functions:generateProjectDraft,functions:updateProjectDraftWithAI,functions:createProjectFromDraft,functions:createBusinessOrg",
    "firebase:deploy:business-org": "firebase deploy --only functions:createBusinessOrg,firestore:rules",
    "firebase:deploy:business-org:function": "firebase deploy --only functions:createBusinessOrg",
    "firebase:deploy:rules": "powershell -ExecutionPolicy Bypass -File scripts/firebase-deploy-rules.ps1",
    "firebase:deploy:rules:equipment": "powershell -ExecutionPolicy Bypass -File scripts/firebase-deploy-rules.ps1 -Only firestore:rules,storage",
    "emulators:functions": "npm run functions:build && firebase emulators:start --only functions",
    "functions:build": "npm run build --prefix functions"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.6.205",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "firebase-tools": "^15.18.0",
    "pdf-lib": "^1.17.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}

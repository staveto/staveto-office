rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function orgMemberData(orgId) {
      return firestore.get(/databases/(default)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isOrgMemberActive(orgId) {
      return isSignedIn() && (
        firestore.get(/databases/(default)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
        || (
          firestore.exists(/databases/(default)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && (
            !('status' in orgMemberData(orgId))
            || orgMemberData(orgId).status in ['active', 'pending']
          )
        )
      );
    }

    function isOrgOwnerOrAdmin(orgId) {
      return isSignedIn() && (
        firestore.get(/databases/(default)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
        || (
          firestore.exists(/databases/(default)/documents/organizations/$(orgId)/members/$(request.auth.uid))
          && orgMemberData(orgId).role in ['admin', 'owner']
          && (
            !('status' in orgMemberData(orgId))
            || orgMemberData(orgId).status == 'active'
          )
        )
      );
    }

    function isOrgChatWriter(orgId) {
      return isOrgMemberActive(orgId) && (
        firestore.get(/databases/(default)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid
        || orgMemberData(orgId).role in ['owner', 'admin', 'manager', 'worker', 'member']
      );
    }

    match /workspaces/{workspaceId}/ai-drafts/{sessionId}/{fileName} {
      allow read: if isSignedIn() && (
        request.auth.uid == workspaceId
        || isOrgMemberActive(workspaceId)
      );
      allow write: if isSignedIn()
        && (
          request.auth.uid == workspaceId
          || isOrgMemberActive(workspaceId)
        )
        && request.resource.size < 25 * 1024 * 1024;
      allow delete: if isSignedIn()
        && (
          request.auth.uid == workspaceId
          || isOrgMemberActive(workspaceId)
        );
    }

    match /projects/{projectId}/documents/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Mirrors firestore.rules canAccessProjectId: project owner, or active
    // member of the project's linked org (orgId, falling back to workspaceId).
    function takeoffProjectData(projectId) {
      return firestore.get(/databases/(default)/documents/projects/$(projectId)).data;
    }

    function canAccessTakeoffProject(projectId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/projects/$(projectId))
        && (
          takeoffProjectData(projectId).ownerId == request.auth.uid
          || (
            takeoffProjectData(projectId).get('orgId', '') != ''
            && takeoffProjectData(projectId).get('orgId', '') != null
            && isOrgMemberActive(takeoffProjectData(projectId).orgId)
          )
          || (
            takeoffProjectData(projectId).get('workspaceId', '') != ''
            && takeoffProjectData(projectId).get('workspaceId', '') != null
            && isOrgMemberActive(takeoffProjectData(projectId).workspaceId)
          )
        );
    }

    // Takeoff images contain drawing/evidence crops and must follow project
    // access, not global signed-in access.
    //
    // Deployment note: these rules read projects/{projectId} (and the linked
    // organization docs) via cross-service firestore.get(). This requires the
    // Firebase Rules cross-service feature (rules_version = '2', enabled for
    // all current projects) and bills one Firestore read per check. There is
    // no rules-unit-testing setup in this repo — verify after deploy that a
    // non-member signed-in user gets storage/unauthorized on these paths.
    match /projects/{projectId}/drawings/{drawingId}/takeoff/{kind}/{fileName} {
      allow read: if canAccessTakeoffProject(projectId);
      allow write: if canAccessTakeoffProject(projectId)
        && kind in ['candidates', 'evidence', 'templates', 'regions']
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if canAccessTakeoffProject(projectId);
    }

    // Problem photos (mobile: projects/{projectId}/problems/{problemId}/{fileName})
    match /projects/{projectId}/problems/{problemId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 15 * 1024 * 1024;
    }

    // Field work photos (mobile: projects/{projectId}/attachments/{attachmentId}/{fileName})
    match /projects/{projectId}/attachments/{attachmentId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 50 * 1024 * 1024;
    }

    match /organizations/{orgId}/profile/{fileName} {
      allow read: if isOrgMemberActive(orgId);
      allow write: if isOrgOwnerOrAdmin(orgId)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isOrgOwnerOrAdmin(orgId);
    }

    match /users/{userId}/equipment/{equipmentId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // AI project draft attachments (mobile/web wizard — before project exists)
    match /users/{userId}/aiProjectDrafts/{draftId}/documents/{fileName} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /organizations/{orgId}/chats/{chatId}/messages/{fileName} {
      allow read: if isOrgMemberActive(orgId);
      allow write: if isOrgChatWriter(orgId)
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isOrgChatWriter(orgId);
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /workspaces/{workspaceId}/ai-drafts/{sessionId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.size < 25 * 1024 * 1024;
    }
  }
}

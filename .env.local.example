# Firebase client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Gmail integration (App Center → Connect Gmail)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/oauth/callback

# Firebase Admin for API routes (JSON string, one line)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional app URL for OAuth redirects in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI Estimator / Kalkulant (quote-first path). When unset/0, classic generateProjectDraft is used.
NEXT_PUBLIC_ENABLE_AI_ESTIMATOR_FLOW=0
# Symbol library + Symbol→Assembly→Product mapping (requires estimator flow).
NEXT_PUBLIC_ENABLE_AI_SYMBOL_LIBRARY=0
# Product sourcing / material price assistance in AI setup (mock + pricebook; no illegal scraping).
NEXT_PUBLIC_ENABLE_PRODUCT_SOURCING=0
# Visual symbol counter for electrical drawings (pixel-level detection of graphical symbols, e.g. switches).
NEXT_PUBLIC_ENABLE_AI_VISUAL_SYMBOL_COUNTER=0
# Interactive PDF evidence viewer + linked takeoff positions in AI setup. Default ON with estimator flow; set 0 to disable.
NEXT_PUBLIC_ENABLE_AI_EVIDENCE_PDF_VIEWER=1
# Optional client/server debug logs for estimator diagnostics (no secrets / full PII).
NEXT_PUBLIC_AI_ESTIMATOR_DEBUG=0
# AI_ESTIMATOR_DEBUG=1
